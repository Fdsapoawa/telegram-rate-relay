{
  "name": "telegram-rate-relay",
  "version": "1.0.0",
  "description": "Multi-source Telegram currency converter for Cloudflare Workers",
  "private": true,
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fdsapoawa/telegram-rate-relay.git"
  },
  "engines": {
    "node": ">=20"
  },
  "cloudflare": {
    "bindings": {
      "TELEGRAM_BOT_TOKEN": {
        "description": "从 Telegram [@BotFather](https://t.me/BotFather) 获取的 Bot Token。"
      },
      "TELEGRAM_WEBHOOK_SECRET": {
        "description": "自定义随机字符串，只能包含字母、数字、下划线和连字符，长度 1 到 256。"
      }
    }
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
